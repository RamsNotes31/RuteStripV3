{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "blockchain:compile": "hardhat compile",
        "blockchain:ganache": "npx ganache --chain.chainId 1337 --wallet.totalAccounts 10",
        "blockchain:deploy": "hardhat run blockchain/scripts/deploy.js --network localhost",
        "blockchain:deploy:local": "hardhat run blockchain/scripts/deploy.js --network localhost",
        "blockchain:deploy:sepolia": "hardhat run blockchain/scripts/deploy.js --network sepolia",
        "blockchain:read": "node blockchain/scripts/get-gpx-version.js"
    },
    "devDependencies": {
        "@nomicfoundation/hardhat-ethers": "^3.0.8",
        "@tailwindcss/vite": "^4.0.0",
        "axios": "^1.11.0",
        "concurrently": "^9.0.1",
        "dotenv": "^16.4.7",
        "ethers": "^6.13.5",
        "hardhat": "^2.22.19",
        "laravel-vite-plugin": "^2.0.0",
        "tailwindcss": "^4.0.0",
        "vite": "^7.0.7"
    }
}
